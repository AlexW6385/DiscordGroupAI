# ===========================================
# 所有配置项以此为准，与 app/config.py 一一对应
# 复制为 .env 后按需修改
# ===========================================

# App
APP_NAME=discord_group_ai
DEBUG=false

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id

# LLM
OPENAI_API_KEY=your-openai-api-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/discord_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# Bot 行为（仅阈值，可选）
RESPONSE_THRESHOLD=0.5
