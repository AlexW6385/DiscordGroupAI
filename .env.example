# ===========================================
# 所有配置项以此为准，与 app/config.py 一一对应
# 复制为 .env 后按需修改
# ===========================================

# App
APP_NAME=discord_group_ai
DEBUG=false

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id

# LLM
OPENAI_API_KEY=your-openai-api-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/discord_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# Bot：是否回复的阈值（0~1，priority >= 此值才回复）
RESPONSE_THRESHOLD=0.5

# 决策：用哪款模型、温度、看最近几条消息
DECISION_MODEL=gpt-4o-mini
DECISION_TEMPERATURE=0.2
DECISION_CONTEXT_MESSAGES=15

# 生成：用哪款模型、温度、看最近几条消息、最少 token 数
GENERATION_MODEL=gpt-4o
GENERATION_TEMPERATURE=0.7
GENERATION_CONTEXT_MESSAGES=30
GENERATION_MIN_TOKENS=32

# 上下文：每个频道在 Redis 里保留多少条、多少秒过期
CONTEXT_MAX_HISTORY=40
CONTEXT_TTL_SECONDS=86400

# 提示词文件（可选，相对或绝对路径；为空则用代码内默认）
# 决策提示词占位: {schema}
# 生成提示词占位: {conversation_log} {max_words} {tone}
DECISION_PROMPT_FILE=prompts/decision.txt
GENERATION_PROMPT_FILE=prompts/generation.txt

# 日志目录（所有 logger 只写文件，控制台只打 内容|分数|回复）
LOG_DIR=logs
